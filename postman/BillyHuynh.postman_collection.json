{
    "info":  {
                 "name":  "BillyHuynh_postmancollection",
                 "_postman_id":  "4f9d5c9e-4a6e-4d93-a2ab-simplebankapp",
                 "description":  "Postman collection for the Simple Bank Spring Boot REST API.",
                 "schema":  "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
             },
    "variable":  [
                     {
                         "key":  "baseUrl",
                         "value":  "http://localhost:8080"
                     },
                     {
                         "key":  "primaryEmail",
                         "value":  ""
                     },
                     {
                         "key":  "receiverEmail",
                         "value":  ""
                     },
                     {
                         "key":  "password",
                         "value":  "password123"
                     },
                     {
                         "key":  "authToken",
                         "value":  ""
                     },
                     {
                         "key":  "accountId",
                         "value":  ""
                     },
                     {
                         "key":  "receiverAccountId",
                         "value":  ""
                     }
                 ],
    "item":  [
                 {
                     "name":  "01 Create Primary Account",
                     "event":  [
                                   {
                                       "listen":  "prerequest",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "if (!pm.collectionVariables.get(\u0027primaryEmail\u0027)) {",
                                                                   "  pm.collectionVariables.set(\u0027primaryEmail\u0027, `primary.${Date.now()}@example.com`);",
                                                                   "}",
                                                                   "pm.collectionVariables.set(\u0027password\u0027, \u0027password123\u0027);"
                                                               ]
                                                  }
                                   },
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027Status is 201 Created\u0027, function () {",
                                                                   "  pm.response.to.have.status(201);",
                                                                   "});",
                                                                   "const json = pm.response.json();",
                                                                   "pm.collectionVariables.set(\u0027accountId\u0027, json.accountId);",
                                                                   "pm.test(\u0027Account ID was returned\u0027, function () {",
                                                                   "  pm.expect(json.accountId).to.be.a(\u0027string\u0027).and.not.empty;",
                                                                   "});"
                                                               ]
                                                  }
                                   }
                               ],
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"name\": \"Primary User\",\n  \"email\": \"{{primaryEmail}}\",\n  \"password\": \"{{password}}\",\n  \"accountType\": \"SAVINGS\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "02 Login",
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027Status is 200 OK\u0027, function () {",
                                                                   "  pm.response.to.have.status(200);",
                                                                   "});",
                                                                   "const json = pm.response.json();",
                                                                   "pm.collectionVariables.set(\u0027authToken\u0027, json.token);",
                                                                   "pm.test(\u0027Auth token was returned\u0027, function () {",
                                                                   "  pm.expect(json.token).to.be.a(\u0027string\u0027).and.not.empty;",
                                                                   "});"
                                                               ]
                                                  }
                                   }
                               ],
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"email\": \"{{primaryEmail}}\",\n  \"password\": \"{{password}}\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/auth/login",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "auth",
                                                              "login"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "03 Create Receiver Account",
                     "event":  [
                                   {
                                       "listen":  "prerequest",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "if (!pm.collectionVariables.get(\u0027receiverEmail\u0027)) {",
                                                                   "  pm.collectionVariables.set(\u0027receiverEmail\u0027, `receiver.${Date.now()}@example.com`);",
                                                                   "}"
                                                               ]
                                                  }
                                   },
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027Status is 201 Created\u0027, function () {",
                                                                   "  pm.response.to.have.status(201);",
                                                                   "});",
                                                                   "const json = pm.response.json();",
                                                                   "pm.collectionVariables.set(\u0027receiverAccountId\u0027, json.accountId);"
                                                               ]
                                                  }
                                   }
                               ],
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"name\": \"Receiver User\",\n  \"email\": \"{{receiverEmail}}\",\n  \"password\": \"{{password}}\",\n  \"accountType\": \"CHECKING\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "04 List Accounts",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "05 Get Account Details",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "06 Deposit Money",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"amount\": 500\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}/deposit",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}",
                                                              "deposit"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "07 Withdraw Money",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"amount\": 100\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}/withdraw",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}",
                                                              "withdraw"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "08 Transfer Money",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"receiverAccountId\": \"{{receiverAccountId}}\",\n  \"amount\": 50\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}/transfer",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}",
                                                              "transfer"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "09 Transaction History - Page 1",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}/transactions?page=0\u0026size=5",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}",
                                                              "transactions"
                                                          ],
                                                 "query":  [
                                                               {
                                                                   "key":  "page",
                                                                   "value":  "0"
                                                               },
                                                               {
                                                                   "key":  "size",
                                                                   "value":  "5"
                                                               }
                                                           ]
                                             }
                                 }
                 },
                 {
                     "name":  "10 Update Account Holder Name",
                     "request":  {
                                     "method":  "PUT",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{authToken}}"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"name\": \"Updated User\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/accounts/{{accountId}}/user",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "accounts",
                                                              "{{accountId}}",
                                                              "user"
                                                          ]
                                             }
                                 }
                 }
             ]
}
