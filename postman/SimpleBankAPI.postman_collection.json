{
  "info": {
    "name": "Simple Bank API",
    "_postman_id": "4f9d5c9e-4a6e-4d93-a2ab-simplebankapp",
    "description": "Postman collection for the Simple Bank Spring Boot REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "primaryEmail",
      "value": ""
    },
    {
      "key": "receiverEmail",
      "value": ""
    },
    {
      "key": "password",
      "value": "password123"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "accountId",
      "value": ""
    },
    {
      "key": "receiverAccountId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 Create Primary Account",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('primaryEmail')) {",
              "  pm.collectionVariables.set('primaryEmail', `primary.${Date.now()}@example.com`);",
              "}",
              "pm.collectionVariables.set('password', 'password123');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accountId', json.accountId);",
              "pm.test('Account ID was returned', function () {",
              "  pm.expect(json.accountId).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Primary User\",\n  \"email\": \"{{primaryEmail}}\",\n  \"password\": \"{{password}}\",\n  \"accountType\": \"SAVINGS\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts"
          ]
        }
      }
    },
    {
      "name": "02 Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('authToken', json.token);",
              "pm.test('Auth token was returned', function () {",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{primaryEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "03 Create Receiver Account",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('receiverEmail')) {",
              "  pm.collectionVariables.set('receiverEmail', `receiver.${Date.now()}@example.com`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('receiverAccountId', json.accountId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Receiver User\",\n  \"email\": \"{{receiverEmail}}\",\n  \"password\": \"{{password}}\",\n  \"accountType\": \"CHECKING\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts"
          ]
        }
      }
    },
    {
      "name": "04 List Accounts",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts"
          ]
        }
      }
    },
    {
      "name": "05 Get Account Details",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}"
          ]
        }
      }
    },
    {
      "name": "06 Deposit Money",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/deposit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}",
            "deposit"
          ]
        }
      }
    },
    {
      "name": "07 Withdraw Money",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/withdraw",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}",
            "withdraw"
          ]
        }
      }
    },
    {
      "name": "08 Transfer Money",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiverAccountId\": \"{{receiverAccountId}}\",\n  \"amount\": 50\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/transfer",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}",
            "transfer"
          ]
        }
      }
    },
    {
      "name": "09 Transaction History - Page 1",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/transactions?page=0&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}",
            "transactions"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      }
    },
    {
      "name": "10 Update Account Holder Name",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/user",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{accountId}}",
            "user"
          ]
        }
      }
    }
  ]
}
